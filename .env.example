# PostgreSQL (local: docker compose / Railway: DATABASE_URL を自動設定)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=fx_user
POSTGRES_PASSWORD=fx_password
POSTGRES_DB=fx_db
DATABASE_URL=

# DynamoDB (local only - Railway では未設定でインメモリキャッシュを使用)
DYNAMODB_ENDPOINT=http://localhost:8001
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# API
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# FRED API (optional)
FRED_API_KEY=

# OpenAI (Railway に登録したキーを使用)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OANDA (optional — 未設定時はペーパー取引)
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=
OANDA_ENVIRONMENT=practice

# TradingView Webhook (optional)
TRADINGVIEW_WEBHOOK_SECRET=

# 自動取引スケジューラ
AUTOTRADE_ENABLED=true
AUTOTRADE_INTERVAL_MINUTES=15

# SaaS / 認証
SAAS_ENABLED=true
SAAS_DEFAULT_PLAN=pro
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRE_HOURS=72
STRIPE_WEBHOOK_SECRET=

# Frontend SaaS（false で従来のオープンアクセス UI）
NEXT_PUBLIC_SAAS_ENABLED=true